# =============================================================================
# DocChat Frontend — Environment Variables (Vite)
# =============================================================================
# Rename this file to .env in the frontend/ directory and fill in real values.
# NEVER commit .env to version control.
#
# NOTE: All variables MUST be prefixed with VITE_ to be exposed to the browser.
# Variables without that prefix are invisible to client-side code.
# =============================================================================

# ── API Connection ────────────────────────────────────────────────────────────

# Base URL of the FastAPI backend (no trailing slash)
# Development:  http://localhost:8000
# Production:   https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# ── App Metadata ──────────────────────────────────────────────────────────────

# Display name shown in browser tab, header, and error pages
VITE_APP_NAME=DocChat

# Short tagline shown on the landing / splash screen
VITE_APP_TAGLINE=AI-Powered Document Assistant

# App version (shown in footer)
VITE_APP_VERSION=1.0.0

# ── File Upload UI ────────────────────────────────────────────────────────────

# Maximum file size in MB shown to the user in the upload dialog
# Should match MAX_UPLOAD_SIZE_MB in backend/.env
VITE_MAX_FILE_SIZE_MB=1000000

# Comma-separated list of accepted file extensions shown in the drag-drop zone
VITE_ACCEPTED_FILE_TYPES=.pdf,.docx,.txt

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Set to "true" to show the debug panel in the chat window (dev only)
VITE_ENABLE_DEBUG_PANEL=false

# Set to "true" to display retrieved source chunks below each AI answer
VITE_SHOW_SOURCES=true
