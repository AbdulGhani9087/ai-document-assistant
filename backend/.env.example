# =============================================================================
# DocChat Backend — Environment Variables
# =============================================================================
# Rename this file to .env in the backend/ directory and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────

# Groq API key for LLaMA 2 (70B / 13B / 7B) text generation
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY

# Which Groq-hosted model to use
# Options: llama2-70b-4096 | llama2-13b-4096 | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL_NAME=llama2-70b-4096

# ── Hugging Face ──────────────────────────────────────────────────────────────

# HF token — only required for private / gated repos
# Get yours at: https://huggingface.co/settings/tokens
# Leave blank ("") to use public models without authentication
HF_TOKEN=

# Sentence-transformer model used to generate dense embeddings
# Default is free and fast; swap for a larger model if needed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────────

# Folder on disk where ChromaDB persists its collections
# Relative paths are resolved from the backend/ directory
CHROMA_PERSIST_DIR=./chroma_store

# Name of the ChromaDB collection that stores document chunks
CHROMA_COLLECTION_NAME=docchat_docs

# ── Database (metadata & sessions) ───────────────────────────────────────────

# SQLite (zero-config, great for development):
DATABASE_URL=sqlite:///./docchat.db

# PostgreSQL example (uncomment and edit for production):
# DATABASE_URL=postgresql://docchat_user:strongpassword@localhost:5432/docchat_db

# ── API / Server ──────────────────────────────────────────────────────────────

# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# Comma-separated list of origins the CORS middleware allows
# Use * only during local development; lock down for production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Upload ───────────────────────────────────────────────────────────────

# Maximum accepted file size in megabytes
MAX_UPLOAD_SIZE_MB=50

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# Directory where uploaded files are temporarily stored before processing
UPLOAD_DIR=./uploads

# ── RAG / Chunking Parameters ─────────────────────────────────────────────────

# Approximate token count per chunk (300–500 recommended)
CHUNK_SIZE=400

# Overlap between consecutive chunks to preserve context at boundaries
CHUNK_OVERLAP=50

# Number of top similar chunks to retrieve for each query
TOP_K_RESULTS=5

# ── Security ──────────────────────────────────────────────────────────────────

# Random secret key used to sign tokens and sessions
# Generate a new one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Token expiry in minutes (used for session-style access tokens)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App Settings ──────────────────────────────────────────────────────────────

# Set to "production" to disable debug output and hot-reload
ENVIRONMENT=development

# Whether to enable FastAPI's /docs and /redoc endpoints
ENABLE_API_DOCS=true

# Application version (shown in API docs)
APP_VERSION=1.0.0
