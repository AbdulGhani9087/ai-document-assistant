# =============================================================================
# DocChat — Root Environment Reference
# =============================================================================
# Copy the relevant sections to backend/.env and frontend/.env then fill in
# your real values.  This file itself is safe to commit.
# =============================================================================

# ── BACKEND vars (copy to backend/.env) ──────────────────────────────────────

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# Hugging Face token — https://huggingface.co/settings/tokens
# Only required for gated / private models.  Leave blank to use public models.
HF_TOKEN=hf_REPLACE_OR_LEAVE_BLANK

# Directory where ChromaDB persists vector data on disk
CHROMA_PERSIST_DIR=./chroma_store

# Database URL
# SQLite  (default, no extra setup): sqlite:///./docchat.db
# PostgreSQL                        : postgresql://user:password@localhost:5432/docchat
DATABASE_URL=sqlite:///./docchat.db

# Comma-separated list of origins allowed by CORS
# Use * for development; lock down in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Maximum file-upload size accepted by the API (MB)
MAX_UPLOAD_SIZE_MB=50

# Chunking parameters
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Number of vector-search results to retrieve per query
TOP_K_RESULTS=5

# Hugging Face embedding model (no token required for this one)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Secret key used to sign sessions / JWTs — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Runtime environment
ENVIRONMENT=development

# ── FRONTEND vars (copy to frontend/.env) ────────────────────────────────────

# Base URL of the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000

# Display name shown in the browser tab / header
VITE_APP_NAME=DocChat

# Max upload size hint shown in the UI (should match MAX_UPLOAD_SIZE_MB above)
VITE_MAX_FILE_SIZE_MB=50
